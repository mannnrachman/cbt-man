generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin_prodi
  evaluator
  mahasiswa
}

enum TipeSoal {
  pg
  multi
  bs
  essay
}

enum Kesulitan {
  mudah
  sedang
  sulit
}

enum StatusSesi {
  belum
  sedang
  selesai
  kedaluwarsa
}

model UnitAkademik {
  id       String         @id
  nama     String
  tipe     String
  parentId String?
  parent   UnitAkademik?  @relation("UnitToUnit", fields: [parentId], references: [id], onDelete: Cascade)
  children UnitAkademik[] @relation("UnitToUnit")
  users    User[]
  mataKuliah MataKuliah[]
}

model User {
  id              String        @id
  username        String        @unique
  passwordHash    String
  namaLengkap     String
  role            Role
  allowedTopikIds String        @default("[]")
  unitId          String?
  mataKuliahIds   String        @default("[]")
  detail          String?
  aktif           Boolean       @default(true)
  createdAt       BigInt
  unit            UnitAkademik? @relation(fields: [unitId], references: [id])
  createdUjians   Ujian[]       @relation("UjianCreator")
  sesi            SesiUjian[]   @relation("SesiPeserta")
  sessions        Session[]     @relation("UserSessions")
}

/// Sesi login server-side. `id` = token opaque 256-bit (randomBytes hex),
/// disimpan di cookie httpOnly. Dihapus saat logout/expiry/deaktivasi-revoke.
model Session {
  id                String   @id
  userId            String
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  userAgent         String?
  deviceFingerprint String?
  user              User     @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Modul {
  id           String  @id
  nama         String
  aktif        Boolean @default(true)
  mataKuliahId String?
  topik        Topik[]
}

model Topik {
  id      String @id
  modulId String
  nama    String
  modul   Modul  @relation(fields: [modulId], references: [id], onDelete: Cascade)
  soal    Soal[]
}

model Soal {
  id            String    @id
  topikId       String
  detail        String
  tipe          TipeSoal
  kesulitan     Kesulitan
  audioFileId   String?
  audioPlayOnce Boolean   @default(false)
  pembahasan    String    @default("")
  createdAt     BigInt
  topik         Topik     @relation(fields: [topikId], references: [id], onDelete: Cascade)
  jawaban       Jawaban[]
}

model Jawaban {
  id     String  @id
  soalId String
  detail String
  benar  Boolean
  soal   Soal    @relation(fields: [soalId], references: [id], onDelete: Cascade)
}

model Ujian {
  id               String       @id
  nama             String
  deskripsi        String       @default("")
  durasiMenit      Int
  poinBenar        Float        @default(1)
  poinSalah        Float        @default(0)
  poinKosong       Float        @default(0)
  beginAt          BigInt?
  endAt            BigInt?
  tokenAktif       Boolean      @default(false)
  ipRange          String       @default("")
  groupIds         String       @default("[]")
  mataKuliahId     String?
  semesterId       String?
  topicSets        String       @default("[]")
  showResult       Boolean      @default(true)
  showResultDetail Boolean      @default(false)
  fullscreenWajib  Boolean      @default(true)
  maxPindahTab     Int          @default(3)
  blokirShortcut   Boolean      @default(true)
  mode             String       @default("online") // "online" | "offline"
  createdBy        String
  createdAt        BigInt
  creator          User         @relation("UjianCreator", fields: [createdBy], references: [id])
  tokens           TokenUjian[]
  sesi             SesiUjian[]
}

model TokenUjian {
  id          String  @id
  ujianId     String
  kode        String
  dipakaiOleh String?
  dipakaiAt   BigInt?
  ujian       Ujian   @relation(fields: [ujianId], references: [id], onDelete: Cascade)

  // Token codes are scoped to an exam so two exams may independently
  // re-use the same short code. Uniqueness is enforced at the DB layer
  // so a stale client cache or a backup import can never persist duplicates.
  @@unique([ujianId, kode])
  @@index([ujianId])
}

model SesiUjian {
  id           String     @id
  ujianId      String
  pesertaId    String
  status       StatusSesi
  mulaiAt      BigInt?
  selesaiAt    BigInt?
  endsAt       BigInt?
  soalIds      String     @default("[]")
  jawabanOrder String     @default("{}")
  jawaban      String     @default("[]")
  pelanggaran  Int        @default(0)
  skorTotal    Float?
  maxSkor      Float?
  gradedAt     BigInt?
  gradedBy     String?
  createdAt    BigInt
  ujian        Ujian      @relation(fields: [ujianId], references: [id], onDelete: Cascade)
  peserta      User       @relation("SesiPeserta", fields: [pesertaId], references: [id])
}

model AppConfig {
  id           String  @id @default("app")
  appName      String  @default("CBT-Kampus")
  appLogo      String  @default("")
  appDeskripsi String  @default("Aplikasi ujian berbasis komputer")
  pesanLogin   String  @default("Selamat datang di aplikasi ujian online")
  mobileLock   Boolean @default(false)
  multiDevice  Boolean @default(false)
  roleAccess   String  @default("{}")
}

model AuditLog {
  id        String   @id
  userId    String
  userRole  String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}



model TahunAkademik {
  id       String     @id
  nama     String
  aktif    Boolean    @default(false)
  semester Semester[]
}

model Semester {
  id              String        @id
  nama            String
  tahunAkademikId String
  tahunAkademik   TahunAkademik @relation(fields: [tahunAkademikId], references: [id], onDelete: Cascade)
  mataKuliah      MataKuliah[]
}

model MataKuliah {
  id         String       @id
  kode       String
  nama       String
  sks        Int          @default(2)
  unitId     String?
  unit       UnitAkademik? @relation(fields: [unitId], references: [id], onDelete: Cascade)
  semesterId String?
  semester   Semester?     @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}
